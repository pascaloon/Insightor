{
  "name": "insightor",
  "displayName": "Insightor",
  "description": "C# Algorithm Helper",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:insightor.startSession",
    "onCommand:insightor.restartSession",
    "onCommand:insightor.stopSession",
    "onCommand:insightor.showTimeline",
    "onCommand:insightor.showVariablesTable",
    "onCommand:insightor.showCallGraph",
    "onCommand:insightor.showAnimator"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "insightor.startSession",
        "title": "Insightor: Start Session"
      },
      {
        "command": "insightor.restartSession",
        "title": "Insightor: Restart Session"
      },
      {
        "command": "insightor.stopSession",
        "title": "Insightor: Stop Session"
      },
      {
        "command": "insightor.showTimeline",
        "title": "Insightor: Show Timeline"
      },
      {
        "command": "insightor.showVariablesTable",
        "title": "Insightor: Show Variables Table"
      },
      {
        "command": "insightor.showCallGraph",
        "title": "Insightor: Show Call Graph"
      },
      {
        "command": "insightor.showAnimator",
        "title": "Insightor: Show Animator"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.104.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2",
    "ts-loader": "^9.5.4",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
